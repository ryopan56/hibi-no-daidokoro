{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "hibi-no-daidokoro backup logs.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "logs"],
  "properties": {
    "version": {
      "const": 1
    },
    "logs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "log_date",
          "time_minutes",
          "taste_level",
          "ingredient_categories",
          "tags",
          "photos"
        ],
        "properties": {
          "log_date": {
            "type": "string",
            "format": "date"
          },
          "time_minutes": {
            "type": ["integer", "null"],
            "enum": [null, 10, 20, 30, 45, 60]
          },
          "taste_level": {
            "type": ["string", "null"],
            "enum": [null, "LOW", "MEDIUM", "HIGH"]
          },
          "ingredient_categories": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": ["MEAT", "FISH", "EGG", "VEGETABLE", "BEAN", "FROZEN"]
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "name"],
              "properties": {
                "kind": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 32
                },
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 64
                }
              }
            }
          },
          "photos": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path"],
              "properties": {
                "path": {
                  "type": "string",
                  "pattern": "^photos/[0-9]{4}-[0-9]{2}-[0-9]{2}/[^/]+$"
                }
              }
            }
          }
        }
      }
    }
  }
}
